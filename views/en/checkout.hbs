<div id="step2" class="container">
  <div class="row justify-content-center">
    <div class="col-lg-12 col-md-12 col-sm-12">
      <div class="my-4">
        <p class="lead mb-1">Complete your payment</p>
        <p class="text-muted mb-0">Review your order and enter your billing details below.</p>
      </div>

      {{#if error}}
      <ul class="text-danger">
        <li>{{error}}</li>
      </ul>
      {{/if}}

      <form id="checkoutForm" class="php-email-form" action="{{withBasePath '/en/auth'}}" name="paymentForm" role="form" method="post">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">

        <div class="container">
          <div class="row">
            <div class="col-lg-4">
              <div class="checkout-card checkout-card-muted fade-in">
                <div class="card-header">
                  Order Summary
                </div>
                <div class="card-body">
                  <div class="order-summary-item">
                    <div class="d-flex justify-content-between align-items-start">
                      <div>
                        <h6 class="text-uppercase mb-1">{{paymentInfo.categoryName}}</h6>
                        <small class="text-muted">{{paymentInfo.description}}</small>
                      </div>
                      <span class="text-success fw-bold">${{formatNumber paymentInfo.price}}</span>
                    </div>

                    {{#if paymentInfo.quantity}}
                    <div class="mt-2">
                      <span class="badge bg-light text-dark border">
                        Quantity: {{paymentInfo.quantity}}
                      </span>
                    </div>
                    {{/if}}
                  </div>

                  {{#if paymentInfo.otherInfo}}
                  <div class="order-summary-item">
                    <h6 class="mb-1">Notes</h6>
                    <small class="text-muted">{{paymentInfo.otherInfo}}</small>
                  </div>
                  {{/if}}

                  <div class="order-total fade-in">
                    <div class="d-flex justify-content-between align-items-center">
                      <span class="total-label">Total Amount</span>
                      <div class="text-end">
                        <div class="total-amount">${{formatNumber paymentInfo.price}}</div>
                        <small class="text-muted">{{paymentInfo.currency}}</small>
                      </div>
                    </div>
                  </div>

                  <div class="summary-meta">
                    <small class="text-muted d-block">Cards accepted: Visa, Mastercard, Amex</small>
                  </div>

                  <div class="text-center mt-3 fade-in summary-ssl">
                    <img
                      src="{{withBasePath '/assets/img/secure-ssl-services.png'}}"
                      alt="SSL Secure Payment"
                      class="img-fluid"
                      style="max-width: 180px;"
                    >
                  </div>
                </div>
              </div>
            </div>

            <div class="col-lg-8">
              <div class="checkout-card fade-in">
                <div class="card-header">
                  Billing Information
                </div>
                <div class="card-body">
                  <div class="section-intro">
                    <p class="mb-0">Your receipt will be sent to the email address you provide below.</p>
                  </div>
                  <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                      <label for="FirstName" class="form-label">First Name</label>
                      <div class="input-icon-group">
                        <i class="bi bi-person field-icon"></i>
                        <input type="text" class="form-control" id="FirstName" name="FirstName" placeholder="John" required value="{{formData.firstName}}">
                      </div>
                    </div>
                    <div class="col-md-6 mb-3">
                      <label for="LastName" class="form-label">Last Name</label>
                      <div class="input-icon-group">
                        <i class="bi bi-person field-icon"></i>
                        <input type="text" class="form-control" id="LastName" name="LastName" placeholder="Doe" required value="{{formData.lastName}}">
                      </div>
                    </div>
                  </div>

                  <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                      <label for="EmailAddress" class="form-label">Email Address</label>
                      <div class="input-icon-group">
                        <i class="bi bi-envelope-at field-icon"></i>
                        <input type="email" class="form-control" id="EmailAddress" name="EmailAddress" placeholder="john.doe@example.com" required value="{{formData.emailAddress}}">
                      </div>
                      <div class="form-text-helper">
                        Your payment receipt will be sent to this email
                      </div>
                    </div>
                    <div class="col-md-6 mb-3">
                      <label for="RepEmailAddress" class="form-label">Sales Rep Email <span class="text-muted">(optional)</span></label>
                      <div class="input-icon-group">
                        <i class="bi bi-person-lines-fill field-icon"></i>
                        <input type="email" class="form-control" id="RepEmailAddress" name="RepEmailAddress" placeholder="sales.rep@example.com" value="{{formData.repEmailAddress}}">
                      </div>
                      <div class="form-text-helper">
                        Copy of receipt will be sent to this email
                      </div>
                    </div>
                  </div>

                  <div class="mb-4">
                    <label for="Line1" class="form-label">Street Address</label>
                    <div class="input-icon-group">
                      <i class="bi bi-geo-alt field-icon"></i>
                      <input type="text" class="form-control" id="Line1" name="Line1" placeholder="1234 Main Street" required value="{{formData.line1}}">
                    </div>
                  </div>

                  <div class="mb-4">
                    <label for="Line2" class="form-label">Address Line 2 <span class="text-muted">(optional)</span></label>
                    <div class="input-icon-group">
                      <i class="bi bi-building field-icon"></i>
                      <input type="text" class="form-control" id="Line2" name="Line2" placeholder="Apartment, suite, or unit" value="{{formData.line2}}">
                    </div>
                  </div>

                  <div class="row mb-4">
                    <div class="col-md-4 mb-3">
                      <label for="StateParish" class="form-label">State/Parish</label>
                      <div class="input-icon-group">
                        <i class="bi bi-map field-icon"></i>
                        <input type="text" class="form-control" id="StateParish" name="StateParish" placeholder="Kingston" required value="{{formData.stateParish}}">
                      </div>
                    </div>

                    <div class="col-md-4 mb-3">
                      <label for="CountryCode" class="form-label">Country</label>
                      <div class="select-icon-group country-select-wrapper">
                        <i class="bi bi-flag field-icon"></i>
                        <select class="form-select" id="CountryCode" name="CountryCode" required>
                          <option value="" disabled>Select Country</option>
                          {{#each countries}}
                          <option value="{{this.code}}" {{#if (eq this.code ../formData.countryCode)}}selected{{/if}}>{{this.name}}</option>
                          {{/each}}
                        </select>
                      </div>
                    </div>

                    <div class="col-md-4 mb-3">
                      <label for="PostalCode" class="form-label">ZIP/Postal Code</label>
                      <div class="input-icon-group">
                        <i class="bi bi-mailbox field-icon"></i>
                        <input type="text" class="form-control" id="PostalCode" name="PostalCode" placeholder="KGN 05" required value="{{formData.postalCode}}">
                      </div>
                    </div>
                  </div>

                  <div class="mb-4">
                    <label for="PhoneNumber" class="form-label">Contact Number</label>
                    <div class="input-icon-group">
                      <i class="bi bi-telephone field-icon"></i>
                      <input type="text" class="form-control" id="PhoneNumber" name="PhoneNumber" placeholder="(876) 555-1234" required value="{{formData.phoneNumber}}">
                    </div>
                    <div class="form-text-helper">
                      Include country code if outside Jamaica
                    </div>
                  </div>

                  <hr class="my-4">

                  <div class="mb-4">
                    <h5 class="section-heading mb-3">Payment Details</h5>

                    <div class="mb-4">
                      <label for="CardholderName" class="form-label">Name on Card</label>
                      <div class="input-icon-group">
                        <i class="bi bi-person-vcard field-icon"></i>
                        <input type="text" class="form-control" id="CardholderName" name="CardholderName" placeholder="JOHN A DOE" required value="{{formData.cardholderName}}">
                      </div>
                      <div class="form-text-helper">
                        Full name as shown on your card
                      </div>
                    </div>

                    <div class="mb-4">
                      <label for="CardPan" class="form-label">Card Number</label>
                      <div class="input-icon-group card-input-group">
                        <i class="bi bi-credit-card field-icon card-icon"></i>
                        <input type="text" class="form-control" id="CardPan" name="CardPan" placeholder="1234 5678 9012 3456" required autocomplete="cc-number">
                      </div>
                    </div>

                    <div class="row">
                      <div class="col-md-4 mb-3">
                        <label for="CardExpiration" class="form-label">Expiration Date</label>
                        <div class="input-icon-group">
                          <i class="bi bi-calendar-event field-icon"></i>
                          <input type="text" class="form-control" id="CardExpiration" name="CardExpiration" placeholder="MM/YY" required autocomplete="cc-exp">
                        </div>
                      </div>

                      <div class="col-md-4 mb-3">
                        <label for="CardCvv" class="form-label">CVV Code</label>
                        <div class="input-icon-group">
                          <i class="bi bi-shield-lock field-icon"></i>
                          <input type="password" class="form-control" id="CardCvv" name="CardCvv" placeholder="123" maxlength="4" autocomplete="off" required>
                        </div>
                        <div class="form-text-helper">
                          3 or 4 digits on your card
                        </div>
                      </div>

                      <div class="col-md-4 mb-3 mt-4">
                        <div class="card cvv-hint">
                          <div class="card-body p-2">
                            <small class="text-muted" style="font-size: 0.75rem;">
                              <i class="bi bi-info-circle me-1"></i>
                              CVV is the security code on your card
                            </small>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  {{#if recaptchaSiteKey}}
                  <div class="mb-4">
                    <div class="g-recaptcha" data-sitekey="{{recaptchaSiteKey}}"></div>
                    <div class="form-text-helper mt-2">
                      Please verify that you are not a robot
                    </div>
                  </div>
                  {{/if}}

                  <div class="d-grid gap-2 d-md-flex justify-content-md-between pt-3 border-top">
                    <a href="{{withBasePath '/en/'}}" class="btn btn-outline-secondary">
                      Back to Services
                    </a>
                    <button type="submit" class="btn btn-primary-custom px-5" id="submitBtn">
                      <span class="btn-spinner spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                      Complete Payment
                    </button>
                  </div>

                  <div class="checkout-note mt-4">
                    <p class="mb-0 small">Transactions are encrypted and processed through a 3D Secure-enabled payment gateway.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="{{withBasePath '/assets/js/jquery-3.7.1.min.js'}}"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cleave.js/1.6.0/cleave.min.js"></script>
<script src="{{withBasePath '/assets/vendor/cleave/cleave-phone.i18n.js'}}"></script>
{{#if recaptchaSiteKey}}
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
{{/if}}
<script src="{{withBasePath '/assets/vendor/bootstrap/js/bootstrap.bundle.min.js'}}"></script>
<script src="{{withBasePath '/assets/vendor/sweetalert/sweetalert2.min.js'}}"></script>

<script>
  $(document).ready(function() {
    const checkoutForm = $('#checkoutForm');
    const submitBtn = $('#submitBtn');

    const countryPhoneCodes = {
      'JM': 'JM',
      'US': 'US',
      'CA': 'CA',
      'GB': 'GB'
    };

    let phoneCleave = null;
    let ccNumberCleave = null;
    let ccDateCleave = null;
    let cvvCleave = null;

    function initializeFormatters() {
      const countryCode = $('#CountryCode').val();
      const phoneRegionCode = countryPhoneCodes[countryCode] || 'US';

      if (phoneCleave) phoneCleave.destroy();
      phoneCleave = new Cleave('#PhoneNumber', {
        phone: true,
        phoneRegionCode: phoneRegionCode,
        onValueChanged: function(e) {
          validatePhone(e.target.value);
        }
      });

      if (ccNumberCleave) ccNumberCleave.destroy();
      ccNumberCleave = new Cleave('#CardPan', {
        creditCard: true,
        onCreditCardTypeChanged: function(type) {
          updateCardIcon(type);
        }
      });

      if (ccDateCleave) ccDateCleave.destroy();
      ccDateCleave = new Cleave('#CardExpiration', {
        date: true,
        datePattern: ['m', 'y'],
        onValueChanged: function(e) {
          validateExpiryDate(e.target.value);
        }
      });

      if (cvvCleave) cvvCleave.destroy();
      cvvCleave = new Cleave('#CardCvv', {
        blocks: [4],
        numericOnly: true,
        onValueChanged: function(e) {
          validateCVV(e.target.value);
        }
      });
    }

    function updateCardIcon(cardType) {
      const cardIcon = $('.card-icon');
      cardIcon.removeClass('text-primary text-warning text-success text-info text-muted');

      switch(cardType) {
        case 'visa':
          cardIcon.addClass('text-primary');
          break;
        case 'mastercard':
          cardIcon.addClass('text-warning');
          break;
        case 'amex':
          cardIcon.addClass('text-success');
          break;
        default:
          cardIcon.addClass('text-muted');
      }
    }

    function validatePhone(phone) {
      const phoneRegex = /^[\+]?[1-9][\d]{6,15}$/;
      const isValid = phoneRegex.test(phone.replace(/\D/g, ''));
      toggleFieldValidation('#PhoneNumber', isValid, 'Please enter a valid phone number');
      return isValid;
    }

    function validateExpiryDate(date) {
      if (!date || date.length < 5) return false;

      const [month, year] = date.split('/');
      const now = new Date();
      const currentYear = now.getFullYear() % 100;
      const currentMonth = now.getMonth() + 1;
      const expiryYear = parseInt(year, 10);
      const expiryMonth = parseInt(month, 10);

      const isValid = expiryMonth >= 1 &&
        expiryMonth <= 12 &&
        ((expiryYear > currentYear) ||
        (expiryYear === currentYear && expiryMonth >= currentMonth));

      toggleFieldValidation('#CardExpiration', isValid, 'Card has expired');
      return isValid;
    }

    function validateCVV(cvv) {
      const isValid = cvv.length >= 3 && cvv.length <= 4;
      toggleFieldValidation('#CardCvv', isValid, 'CVV must be 3-4 digits');
      return isValid;
    }

    function validateEmail(email, selector) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      const isValid = emailRegex.test(email);
      toggleFieldValidation(selector, isValid, 'Please enter a valid email');
      return isValid;
    }

    function toggleFieldValidation(selector, isValid, message) {
      const field = $(selector);
      let feedback = field.siblings('.invalid-feedback');

      if (!isValid && field.val()) {
        field.addClass('is-invalid');
        if (feedback.length === 0) {
          field.after(`<div class="invalid-feedback">${message}</div>`);
        }
      } else {
        field.removeClass('is-invalid');
        feedback.remove();
      }
    }

    $('.form-control').on('blur', function() {
      const field = $(this);
      const value = field.val();

      if (!value && field.prop('required')) {
        field.addClass('is-invalid');
        return;
      }

      switch(field.attr('id')) {
        case 'EmailAddress':
          validateEmail(value, '#EmailAddress');
          break;
        case 'RepEmailAddress':
          if (value) validateEmail(value, '#RepEmailAddress');
          break;
        case 'PhoneNumber':
          validatePhone(value);
          break;
        case 'CardExpiration':
          validateExpiryDate(value);
          break;
        case 'CardCvv':
          validateCVV(value);
          break;
      }
    });

    $('#CountryCode').on('change', function() {
      initializeFormatters();
    });

    checkoutForm.on('submit', function(e) {
      e.preventDefault();

      if (typeof grecaptcha !== 'undefined' && grecaptcha.getResponse() === '') {
        Swal.fire({
          icon: 'error',
          title: 'Security Check Required',
          text: 'Please complete the reCAPTCHA verification.',
          confirmButtonColor: '#dc3545'
        });
        return;
      }

      let isValid = true;
      $('[required]').each(function() {
        if (!$(this).val()) {
          $(this).addClass('is-invalid');
          isValid = false;
        }
      });

      if (!isValid) {
        Swal.fire({
          icon: 'warning',
          title: 'Missing Information',
          text: 'Please fill in all required fields.',
          confirmButtonColor: '#dc3545'
        });
        return;
      }

      submitBtn.addClass('loading').prop('disabled', true);

      setTimeout(() => {
        this.submit();
      }, 300);
    });

    $('.form-control').on('focus', function() {
      $(this).parent().addClass('focused');
    }).on('blur', function() {
      $(this).parent().removeClass('focused');
    });

    initializeFormatters();
  });
</script>
