<div class="container admin-shell py-4">
  <div class="admin-page-head mb-4">
    <div>
      <span class="admin-eyebrow">Operations</span>
      <h1 class="admin-page-title mb-2">Dashboard</h1>
      <p class="admin-page-copy mb-0">Manage services, categories, recent payments, and subscriber activity from one place.</p>
    </div>
    <div class="admin-head-actions">
      <a href="{{withBasePath '/admin/dashboard/sales'}}" class="btn btn-outline-secondary">View Sales</a>
      <a href="{{withBasePath '/admin/users'}}" class="btn btn-primary-custom text-white">Manage Users</a>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
      <div class="admin-metric-card">
        <span class="admin-metric-label">Services</span>
        <strong class="admin-metric-value">{{services.length}}</strong>
        <span class="admin-metric-note">Configured payment services</span>
      </div>
    </div>
    <div class="col-sm-6 col-xl-3">
      <div class="admin-metric-card">
        <span class="admin-metric-label">Categories</span>
        <strong class="admin-metric-value">{{categories.length}}</strong>
        <span class="admin-metric-note">Payment categories available</span>
      </div>
    </div>
    <div class="col-sm-6 col-xl-3">
      <div class="admin-metric-card">
        <span class="admin-metric-label">Recent Sales</span>
        <strong class="admin-metric-value">{{sales.length}}</strong>
        <span class="admin-metric-note">Latest transactions loaded</span>
      </div>
    </div>
    {{!-- <div class="col-sm-6 col-xl-3">
      <div class="admin-metric-card">
        <span class="admin-metric-label">Subscribers</span>
        <strong class="admin-metric-value">{{subscribers.length}}</strong>
        <span class="admin-metric-note">Latest subscriber records loaded</span>
      </div>
    </div> --}}
    <div class="col-sm-6 col-xl-3">
      <div class="admin-metric-card">
        <span class="admin-metric-label">Rates</span>
        <strong class="admin-metric-value">{{printAndSubRates.length}}</strong>
        <span class="admin-metric-note">Subscription and print plans available</span>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-xl-7">
      <div class="admin-panel">
        <div class="admin-panel-header">
          <div>
            <h2 class="admin-panel-title">Services</h2>
            <p class="admin-panel-copy mb-0">Create, review, and update the services exposed to the payment flow.</p>
          </div>
          <button type="button" class="btn btn-primary-custom text-white" id="createNewServiceBtn" data-bs-toggle="modal" data-bs-target="#editServiceModal">Create Service</button>
        </div>
        <div class="admin-table-wrap">
          <table class="table admin-table align-middle small dtService">
            <thead>
              <tr>
                <th>Service</th>
                <th>Category</th>
                <th>Price</th>
                <th>Status</th>
                <th class="text-end">Action</th>
              </tr>
            </thead>
            <tbody>
              {{#each services}}
              <tr>
                <td>
                  <div class="admin-service-cell">
                    <img src="{{image}}" alt="{{name}}" class="admin-service-thumb">
                    <div>
                      <div class="admin-table-title">{{name}}</div>
                      <div class="admin-table-meta">{{description}}</div>
                    </div>
                  </div>
                </td>
                <td>{{Category.name}}</td>
                <td>
                  {{#if useSubscriptionRates}}
                  <span class="admin-inline-note">Adhoc Rate Table: {{subscriptionRateType}}</span>
                  {{else}}
                  {{currency}} {{price}}
                  {{/if}}
                </td>
                <td>
                  <span class="admin-status {{#if active}}is-active{{else}}is-inactive{{/if}}">
                    {{#if active}}Active{{else}}Inactive{{/if}}
                  </span>
                </td>
                <td class="text-end">
                  <button type="button" class="btn btn-sm btn-outline-secondary edit-service" data-bs-toggle="modal" data-bs-target="#editServiceModal" data-id="{{serviceId}}">
                    Edit
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-xl-5">
      <div class="admin-panel">
        <div class="admin-panel-header">
          <div>
            <h2 class="admin-panel-title">Categories</h2>
            <p class="admin-panel-copy mb-0">Keep category labels and descriptions tidy for the public checkout flow.</p>
          </div>
          <button type="button" class="btn btn-outline-secondary" id="createNewCategoryBtn" data-bs-toggle="modal" data-bs-target="#editCategoryModal">Create Category</button>
        </div>
        <div class="admin-table-wrap">
          <table class="table admin-table align-middle small dtCategory">
            <thead>
              <tr>
                <th>Category</th>
                <th>Status</th>
                <th class="text-end">Action</th>
              </tr>
            </thead>
            <tbody>
              {{#each categories}}
              <tr>
                <td>
                  <div class="admin-table-title">{{dataValues.name}}</div>
                  <div class="admin-table-meta">{{dataValues.description}}</div>
                </td>
                <td>
                  <span class="admin-status {{#if dataValues.active}}is-active{{else}}is-inactive{{/if}}">
                    {{#if dataValues.active}}Active{{else}}Inactive{{/if}}
                  </span>
                </td>
                <td class="text-end">
                  <button type="button" class="btn btn-sm btn-outline-secondary edit-category" data-bs-toggle="modal" data-bs-target="#editCategoryModal" data-id="{{dataValues.categoryId}}">
                    Edit
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-xl-12">
      <div class="admin-panel">
        <div class="admin-panel-header">
          <div>
            <h2 class="admin-panel-title">Print & Subscription Rates</h2>
            <p class="admin-panel-copy mb-0">Manage the plans pulled into rate-driven subscription services from the Adhoc database.</p>
          </div>
          <button type="button" class="btn btn-outline-secondary" id="createNewRateBtn" data-bs-toggle="modal" data-bs-target="#editRateModal">Create Rate</button>
        </div>
        <div class="admin-table-wrap">
          <table class="table admin-table align-middle small dtRate">
            <thead>
              <tr>
                <th>Description</th>
                <th>Market</th>
                <th>Type</th>
                <th>Term</th>
                <th>Price</th>
                <th>Status</th>
                <th class="text-end">Action</th>
              </tr>
            </thead>
            <tbody>
              {{#each printAndSubRates}}
              <tr>
                <td>
                  <div class="admin-table-title">{{rateDescription}}</div>
                  <div class="admin-table-meta">Sort: {{sortOrder}}</div>
                </td>
                <td>{{market}}</td>
                <td>{{type}}</td>
                <td>{{#if term}}{{term}} {{termUnit}}{{else}}-{{/if}}</td>
                <td>{{currency}} {{formatNumber rate}}</td>
                <td>
                  <span class="admin-status {{#if active}}is-active{{else}}is-inactive{{/if}}">
                    {{#if active}}Active{{else}}Inactive{{/if}}
                  </span>
                </td>
                <td class="text-end">
                  <button type="button" class="btn btn-sm btn-outline-secondary edit-rate" data-bs-toggle="modal" data-bs-target="#editRateModal" data-id="{{rateId}}">
                    Edit
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-xl-6">
      <div class="admin-panel">
        <div class="admin-panel-header">
          <div>
            <h2 class="admin-panel-title">Recent Sales</h2>
            <p class="admin-panel-copy mb-0">The latest payment records for a quick status check.</p>
          </div>
          <a href="{{withBasePath '/admin/dashboard/sales'}}" class="btn btn-outline-secondary">Open Full View</a>
        </div>
        <div class="admin-table-wrap">
          <table class="table admin-table align-middle small">
            <thead>
              <tr>
                <th>Product</th>
                <th>Amount</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              {{#each sales}}
              <tr>
                <td>
                  <div class="admin-table-title">{{dataValues.serviceName}}</div>
                  <div class="admin-table-meta">{{dataValues.paymentStatus}}</div>
                </td>
                <td>{{dataValues.currency}} {{formatNumber dataValues.amount}}</td>
                <td>{{formatTimeDate dataValues.paymentDate}}</td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-xl-6">
      <div class="admin-panel">
        <div class="admin-panel-header">
          <div>
            <h2 class="admin-panel-title">Recent Subscribers</h2>
            <p class="admin-panel-copy mb-0">Latest signups pulled from the subscription feed.</p>
          </div>
          <span class="admin-inline-note">Latest 10</span>
        </div>
        <div class="admin-table-wrap">
          <table class="table admin-table align-middle small">
            <thead>
              <tr>
                <th>Name</th>
                <th>Plan</th>
                <th>Registered</th>
              </tr>
            </thead>
            <tbody>
              {{#each subscribers}}
              <tr>
                <td>{{dataValues.firstName}} {{dataValues.lastName}}</td>
                <td>{{dataValues.planDesc}}</td>
                <td>{{formatTimeDate dataValues.createdAt}}</td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

{{> dashboard/serviceModal }}
{{> dashboard/categoryModal }}
{{> dashboard/rateModal }}

<script src="{{withBasePath '/assets/js/jquery-3.7.1.min.js'}}"></script>
<script src="https://cdn.datatables.net/v/bs5/jszip-2.5.0/dt-1.13.4/b-2.3.6/b-html5-2.3.6/b-print-2.3.6/r-2.4.1/sb-1.4.2/sp-2.1.2/datatables.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.2.9/js/dataTables.responsive.js"></script>
{{> dashboard/scripts }}
