<script>
    // Global GLightbox instance
    var lightbox = GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      zoomable: true,
    });

    // Enhanced createRadioButton function
    function createRadioButton(index, service) {
      var card = document.createElement('div');
      card.className = 'service-card fade-in';
      card.style.animationDelay = (index * 0.05) + 's';
      card.tabIndex = 0;

      // Radio button
      var radioInput = document.createElement('input');
      radioInput.type = 'radio';
      radioInput.name = 'service';
      radioInput.id = 'service' + index;
      radioInput.value = service.serviceId;
      radioInput.dataset.text = service.name;
      radioInput.dataset.desc = service.description;
      radioInput.className = 'form-check-input';
      radioInput.required = true;

      // Service title
      var title = document.createElement('h5');
      title.className = 'service-card-title mb-2';
      title.textContent = service.name;

      // Service description
      var description = document.createElement('p');
      description.className = 'service-description mb-3';
      description.textContent = service.description;

      // Price section
      var priceSection = document.createElement('div');
      priceSection.className = 'mb-3';

      if (service.price !== null && service.price !== 0) {
        // Fixed price service
        var priceDisplay = document.createElement('div');
        priceDisplay.className = 'service-price';
        priceDisplay.innerHTML = service.currency + ' $' + 
          parseFloat(service.price).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",") +
          '<small class="ms-2">(Fixed price)</small>';
        priceSection.appendChild(priceDisplay);

        // Hidden inputs
        var priceHidden = document.createElement('input');
        priceHidden.type = 'hidden';
        priceHidden.name = 'price';
        priceHidden.value = service.price;

        var currencyHidden = document.createElement('input');
        currencyHidden.type = 'hidden';
        currencyHidden.name = 'currency';
        currencyHidden.value = service.currency;

        // Quantity dropdown
        var quantityDiv = document.createElement('div');
        quantityDiv.className = 'mt-2';
        quantityDiv.style.display = 'none';

        var quantityLabel = document.createElement('label');
        quantityLabel.className = 'form-label';
        quantityLabel.textContent = 'Quantity';
        quantityLabel.htmlFor = 'quantity' + index;

        var quantitySelect = document.createElement('select');
        quantitySelect.id = 'quantity' + index;
        quantitySelect.name = 'quantity';
        quantitySelect.className = 'form-select w-auto';
        quantitySelect.style.display = 'none';

        for (let qty = 1; qty <= 5; qty++) {
          var option = document.createElement('option');
          option.value = qty;
          option.textContent = qty;
          quantitySelect.appendChild(option);
        }

        quantityDiv.appendChild(quantityLabel);
        quantityDiv.appendChild(quantitySelect);
        priceSection.appendChild(quantityDiv);

        // Image if available
        if (service.image) {
          var imageDiv = document.createElement('div');
          imageDiv.className = 'service-image-container mt-2';

          var imgLink = document.createElement('a');
          imgLink.href = service.image;
          imgLink.dataset.title = service.name;
          imgLink.className = 'glightbox';

          var img = document.createElement('img');
          img.src = service.image;
          img.alt = service.name;
          img.className = 'img-fluid';

          var magnifier = document.createElement('i');
          magnifier.className = 'bi bi-search magnifier-icon';

          imgLink.appendChild(img);
          imageDiv.appendChild(imgLink);
          imageDiv.appendChild(magnifier);
          priceSection.appendChild(imageDiv);
        }

        card.appendChild(priceHidden);
        card.appendChild(currencyHidden);
      } else {
        // Custom price service
        var priceInputGroup = document.createElement('div');
        priceInputGroup.className = 'mb-3';
        priceInputGroup.style.display = 'none';

        var row = document.createElement('div');
        row.className = 'row g-3';

        // Currency selection
        var currencyCol = document.createElement('div');
        currencyCol.className = 'col-md-3';

        var currencyLabel = document.createElement('label');
        currencyLabel.className = 'form-label';
        currencyLabel.textContent = 'Currency';
        currencyLabel.htmlFor = 'currency' + index;

        var currencySelect = document.createElement('select');
        currencySelect.id = 'currency' + index;
        currencySelect.name = 'currency';
        currencySelect.className = 'form-select';
        currencySelect.required = true;

        ['JMD', 'USD'].forEach(function(currency) {
          var option = document.createElement('option');
          option.value = currency;
          option.textContent = currency;
          currencySelect.appendChild(option);
        });

        currencyCol.appendChild(currencyLabel);
        currencyCol.appendChild(currencySelect);

        // Amount input
        var amountCol = document.createElement('div');
        amountCol.className = 'col-md-6';

        var amountLabel = document.createElement('label');
        amountLabel.className = 'form-label';
        amountLabel.textContent = 'Amount';
        amountLabel.htmlFor = 'price' + index;

        var inputGroup = document.createElement('div');
        inputGroup.className = 'input-group';

        var dollarSign = document.createElement('span');
        dollarSign.className = 'input-group-text';
        dollarSign.textContent = '$';

        var priceInput = document.createElement('input');
        priceInput.type = 'text';
        priceInput.id = 'price' + index;
        priceInput.name = 'price';
        priceInput.className = 'form-control';
        priceInput.placeholder = '0.00';
        priceInput.required = true;

        inputGroup.appendChild(dollarSign);
        inputGroup.appendChild(priceInput);
        amountCol.appendChild(amountLabel);
        amountCol.appendChild(inputGroup);

        row.appendChild(currencyCol);
        row.appendChild(amountCol);
        priceInputGroup.appendChild(row);

        // Notes
        var notesDiv = document.createElement('div');
        notesDiv.className = 'mb-3';
        notesDiv.style.display = 'none';

        var notesLabel = document.createElement('label');
        notesLabel.className = 'form-label';
        notesLabel.textContent = 'Additional Notes';
        notesLabel.htmlFor = 'otherInfo' + index;

        var notesTextarea = document.createElement('textarea');
        notesTextarea.id = 'otherInfo' + index;
        notesTextarea.name = 'otherInfo';
        notesTextarea.className = 'form-control';
        notesTextarea.rows = '2';
        notesTextarea.placeholder = 'Enter any additional information about your payment...';

        notesDiv.appendChild(notesLabel);
        notesDiv.appendChild(notesTextarea);

        card.appendChild(priceInputGroup);
        card.appendChild(notesDiv);
      }

      // Event listeners for radio selection
      radioInput.addEventListener('change', function() {
        // Update card styling
        document.querySelectorAll('.service-card').forEach(function(card) {
          card.classList.remove('selected');
        });
        card.classList.add('selected');

        // Enable submit button
        document.getElementById('nextBtn').disabled = false;

        // Show/hide relevant fields
        document.querySelectorAll('.service-card').forEach(function(otherCard) {
          if (otherCard !== card) {
            // Hide fields in other cards
            otherCard.querySelectorAll('[style*="display: block"]').forEach(function(el) {
              el.style.display = 'none';
            });
            otherCard.querySelectorAll('[required]').forEach(function(el) {
              el.required = false;
            });
          }
        });

        // Show fields in selected card
        var priceInputGroup = card.querySelector('.mb-3');
        if (priceInputGroup) priceInputGroup.style.display = 'block';

        var quantityDiv = card.querySelector('.mt-2');
        if (quantityDiv) {
          quantityDiv.style.display = 'block';
          card.querySelector('select[name="quantity"]').style.display = 'block';
        }

        var notesDiv = card.querySelector('.mb-3:nth-child(3)');
        if (notesDiv) notesDiv.style.display = 'block';

        // Update hidden fields
        $('#serviceText').val(this.dataset.text);
        $('#description').val(this.dataset.desc);

        // Initialize Cleave for price input
        var priceInput = card.querySelector('input[id="price' + index + '"]');
        if (priceInput && !priceInput.dataset.cleave) {
          new Cleave(priceInput, {
            numeral: true,
            numeralPositiveOnly: true,
            numeralDecimalMark: '.',
            delimiter: ','
          });
          priceInput.dataset.cleave = 'true';
        }
      });

      function shouldIgnoreCardClick(target) {
        return Boolean(target.closest('a, button, input, select, textarea, label'));
      }

      function activateCardSelection() {
        if (!radioInput.checked) {
          radioInput.checked = true;
        }
        radioInput.dispatchEvent(new Event('change', { bubbles: true }));
      }

      card.addEventListener('click', function(event) {
        if (shouldIgnoreCardClick(event.target)) {
          return;
        }

        activateCardSelection();
      });

      card.addEventListener('keydown', function(event) {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          activateCardSelection();
        }
      });

      // Assemble card
      card.appendChild(radioInput);
      card.appendChild(title);
      card.appendChild(description);
      card.appendChild(priceSection);

      return card;
    }

	    // Function to load services
	    function loadServices(categoryId) {
	      $('#serviceOptions').empty();
	      $('#emptySelectionState').hide();
	      $('#categoryList').hide();
	      $('#loadingState').show();
	      $('#errorState').hide();
	      $('#nextBtn').disabled = true;

      $.ajax({
        url: '{{withBasePath "/en/service"}}',
        method: 'POST',
        data: { id: categoryId },
	        success: function(response) {
	          $('#loadingState').hide();
	          $('#categoryList').show();
	          $('#emptySelectionState').hide();

	          if (response.services && response.services.length > 0) {
            response.services.forEach(function(service, index) {
              var radioButton = createRadioButton(index, service);
              $('#serviceOptions').append(radioButton);
            });
            lightbox.reload();
          } else {
            $('#serviceOptions').html(`
              <div class="alert alert-warning text-center">
                <i class="bi bi-exclamation-circle-fill me-2"></i>
                No services available for this category at the moment.
                <p class="mt-2 small">Please select another category or contact support.</p>
              </div>
            `);
          }
        },
	        error: function(err) {
	          $('#loadingState').hide();
	          $('#categoryList').hide();
	          $('#emptySelectionState').hide();
	          $('#errorState').show();
	          console.error('Error loading services', err);
	        }
	      });
	    }

    // Document ready
    $(document).ready(function() {
      // Initialize tooltips
      var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
      var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
      });

      // Category change handler
      $('#category').on('change', function() {
        var categoryId = $(this).val();
        var categoryName = $(this).find('option:selected').text();
        
        $('#categoryName').val(categoryName);
        
	        if (!categoryId) {
	          $('#categoryList').hide();
	          $('#loadingState').hide();
	          $('#errorState').hide();
	          $('#emptySelectionState').show();
	          $('#nextBtn').prop('disabled', true);
	          return;
	        }

        loadServices(categoryId);
      });

      // Form submission handler
      $('#step1Form').on('submit', function(event) {
        event.preventDefault();
        
        var selectedService = $('input[name="service"]:checked');
        
        if (!selectedService.length) {
          Swal.fire({
            icon: 'warning',
            title: 'Selection Required',
            text: 'Please select a service to continue.',
            confirmButtonColor: '#dc3545'
          });
          return;
        }

        // Validate custom price inputs
        var priceInput = selectedService.closest('.service-card').find('input[name="price"]');
        
        if (priceInput.length) {
          var price = priceInput.val();
          if (!price || isNaN(parseFloat(price))) {
            Swal.fire({
              icon: 'error',
              title: 'Invalid Amount',
              text: 'Please enter a valid amount for the service.',
              confirmButtonColor: '#dc3545'
            });
            return;
          }
        }

        // Gather data
        var serviceName = selectedService.data('text');
        var serviceDesc = selectedService.data('desc');
        var currency = selectedService.closest('.service-card').find('select[name="currency"]').val() ||
                      selectedService.closest('.service-card').find('input[name="currency"]').val();
        var price = selectedService.closest('.service-card').find('input[name="price"]').val();
        var quantity = selectedService.closest('.service-card').find('select[name="quantity"]').val();
        var otherInfo = selectedService.closest('.service-card').find('textarea[name="otherInfo"]').val();
        price = (price || '').replace(/,/g, '');

        // Set hidden fields
        $('#serviceText').val(serviceName);
        $('#description').val(serviceDesc);
        $('#currencyhd').val(currency);
        $('#totalAmount').val(price);
        $('#count').val(quantity || 1);
        $('#otherInfohd').val(otherInfo || '');

        // Submit form
        this.submit();
      });

      // Floating help button
      $('.floating-help').on('click', function() {
        Swal.fire({
          title: 'Need Help?',
          html: `
            <div class="text-start">
              <p><strong>Payment Assistance:</strong></p>
              <ul class="mb-3">
                <li>Select a category from the dropdown</li>
                <li>Choose the specific service you need</li>
                <li>Enter payment details if required</li>
                <li>Continue to checkout</li>
              </ul>
              <p><strong>Support Contacts:</strong></p>
              <p>📞 +1 876 936 9534<br>✉️ userhelp@jamaicaobserver.com</p>
            </div>
          `,
          icon: 'info',
          confirmButtonText: 'Got it!',
          confirmButtonColor: '#dc3545'
        });
      });

      // Page load reset
      $('#category').val('').trigger('change');
    });
  </script>
