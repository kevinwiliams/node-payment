<script>
    const dashboardCsrfToken = (function() {
        const tokenTag = document.querySelector('meta[name="csrf-token"]');
        return tokenTag ? tokenTag.getAttribute('content') : '';
    })();

    function withCsrf(data) {
        if (!dashboardCsrfToken) {
            return data;
        }

        if (data instanceof FormData) {
            if (data.has('_csrf')) {
                data.set('_csrf', dashboardCsrfToken);
            } else {
                data.append('_csrf', dashboardCsrfToken);
            }
            return data;
        }

        return Object.assign({ _csrf: dashboardCsrfToken }, data || {});
    }

    if (window.jQuery && dashboardCsrfToken) {
        $.ajaxSetup({
            beforeSend: function(xhr) {
                xhr.setRequestHeader('x-csrf-token', dashboardCsrfToken);
            }
        });
    }

    $(document).ready(function () {
        $('.dtCategory').DataTable({
            lengthChange: false,
            searching: true,
            responsive: true,
            autoWidth: false,
            pageLength: 6,
            dom: '<"admin-datatable-head"f>rt<"admin-datatable-foot"ip>',
            language: {
                search: '',
                searchPlaceholder: 'Search categories'
            },
            columnDefs: [
                { targets: -1, orderable: false, searchable: false, width: '90px' }
            ]
        });

        $('.dtService').DataTable({
            lengthChange: false,
            responsive: true,
            autoWidth: false,
            dom: '<"admin-datatable-head"f>rt<"admin-datatable-foot"ip>',
            pageLength: 6,
            language: {
                search: '',
                searchPlaceholder: 'Search services'
            },
            columnDefs: [
                { targets: -1, orderable: false, searchable: false, width: '90px' }
            ]
        });

        $('.dtRate').DataTable({
            lengthChange: false,
            responsive: true,
            autoWidth: false,
            dom: '<"admin-datatable-head"f>rt<"admin-datatable-foot"ip>',
            pageLength: 6,
            language: {
                search: '',
                searchPlaceholder: 'Search rates'
            },
            columnDefs: [
                { targets: -1, orderable: false, searchable: false, width: '90px' }
            ]
        });
    });

    function ReloadPage() {
        location.reload();
    }
    // Listen for click event on edit category button
    $('.edit-category').on('click', function() {
        var categoryId = $(this).data('id'); // Get the category ID from the button
        // Use AJAX to fetch category data based on the ID
        $.ajax({
            url: '{{withBasePath "/admin/dashboard/getcategory"}}', // Replace with your actual route to fetch category data
            method: 'POST',
            dataType: 'json',
            data: withCsrf({ categoryId: categoryId }),
            success: function(response) {
                const category = response.category;
                // Populate form fields with category data
                $('#categoryId').val(categoryId);
                $('#categoryName').val(category.name);
                $('#categoryDesc').val(category.description);
                $('#categoryActive').prop('checked', category.active);
                // Similar for other fields
            },
            error: function(err) {
                console.error(err);
                // Handle error
            }
        });
    });

    $('#editCategoryForm').submit(function(event) {
        event.preventDefault();
        $.ajax({
            url: $(this).data('request-url'), // URL from data-request-url attribute
            method: 'POST',
            data: withCsrf({
                categoryId: $('#categoryId').val(),
                categoryName: $('#categoryName').val(),
                categoryDesc: $('#categoryDesc').val(),
                categoryActive: $('#categoryActive').is(':checked')
            }),
            success: function(response) {
                if (response.success) {
                    Swal.fire({
                        title: "Success!",
                        text: "Category updated successfully!",
                        icon: "success",
                        dangerMode: false
                    });

                    setTimeout(
                        ReloadPage
                        , 1500);
                } else {
                    Swal.fire({
                        title: "Error!",
                        text: "Something went wrong. Please try again later!",
                        icon: "warning",
                        dangerMode: true
                    });
                }
            
            },
            error: function(xhr, status, error) {
                // Handle error response
                console.error('Error creating category:', error);
                Swal.fire({
                        title: "Error updating category!",
                        text: error,
                        icon: "warning",
                        dangerMode: true
                    });
            }
        });
    });

    $('#deleteCategoryBtn').click(function() {
        Swal.fire({
            title: "Are you sure?",
            text: "You won't be able to revert this!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, delete it!"
            }).then(function(result){
            if (result.isConfirmed) {
                $.ajax({
                    url: '{{withBasePath "/admin/dashboard/deletecategory"}}', // URL from data-request-url attribute
                    method: 'POST',
                    data: withCsrf({
                        categoryId: $('#categoryId').val()
                    }),
                    success: function(response) {
                        // Handle success response
                        Swal.fire({
                            title: "Deleted!",
                            text: "The category has been deleted.",
                            icon: "success"
                        });

                    setTimeout(
                        ReloadPage
                        , 1500);
                    },
                    error: function(xhr, status, error) {
                        // Handle error response
                        console.error('Error deleting category:', error);
                        Swal.fire({
                            title: "Error!",
                            text: error,
                            icon: "error",
                            dangerMode: true
                        });
                        }
                    });
                
            }
        });
        
    });
    
    // Listen for click event on edit service button
    $('.edit-service').on('click', function() {
        var serviceId = $(this).data('id'); // Get the service ID from the button
        // Use AJAX to fetch service data based on the ID
        $.ajax({
            url: '{{withBasePath "/admin/dashboard/getservice"}}', // Replace with your actual route to fetch service data
            method: 'POST',
            dataType: 'json',
            data: withCsrf({ serviceId: serviceId }),
            success: function(response) {
                const service = response.service;
                // Populate form fields with service data
                $('#serviceId').val(service.serviceId);
                $('#serviceCategory').val(service.categoryId);
                $('#serviceName').val(service.name);
                $('#serviceDesc').val(service.description);
                $('#serviceCurrency').val(service.currency);
                $('#servicePrice').val(service.price);
                $('#serviceEpaperDays').val(service.epaperDays);
                $('#subscriptionRateType').val(service.subscriptionRateType || 'Epaper');
                $('#serviceUseSubscriptionRates').prop('checked', Boolean(service.useSubscriptionRates)).trigger('change');
                $('#serviceActive').prop('checked', service.active);
                // Similar for other fields
            },
            error: function(err) {
                console.error(err);
                Swal.fire({
                    title: "Error!",
                    text: err.responseJSON?.message || 'Unable to load the service.',
                    icon: "error",
                    dangerMode: true
                });
                // Handle error
            }
        });
    });

    $('#editServiceForm').submit(function(event) {
        event.preventDefault();
        // Prepare FormData for AJAX submission
        const formData = new FormData(this);
        // Add `serviceActive` checkbox value explicitly
        const isActive = $('#serviceActive').is(':checked');
        const useSubscriptionRates = $('#serviceUseSubscriptionRates').is(':checked');
        formData.set('serviceActive', isActive);
        formData.set('serviceUseSubscriptionRates', useSubscriptionRates);
        formData.set('subscriptionRateType', $('#subscriptionRateType').val());
        withCsrf(formData);

        $.ajax({
            url: $(this).data('request-url'), // URL from data-request-url attribute
            method: 'POST',
            data: formData,
            processData: false, // Required for FormData
            contentType: false, // Required for FormData 
            
            success: function(response) {
                if (response.success) {
                    Swal.fire({
                        title: "Success!",
                        text: "Service updated successfully!",
                        icon: "success",
                        dangerMode: false
                    });

                    setTimeout(
                        ReloadPage
                        , 1500);
                } else {
                    Swal.fire({
                        title: "Error!",
                        text: "Something went wrong| Please try again later!",
                        icon: "warning",
                        dangerMode: true
                    });
                }
            },
            error: function(xhr, status, error) {
                // Handle error response
                console.error('Error creating service:', error);
                Swal.fire({
                    title: "Error!",
                    text: error,
                    icon: "error",
                    dangerMode: true
                });
            }
        });
    });

    $('#deleteServiceBtn').click(function() {

        Swal.fire({
            title: "Are you sure?",
            text: "You won't be able to revert this!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, delete it!"
            }).then(function(result){
                if (result.isConfirmed) {
                    $.ajax({
                        url: '{{withBasePath "/admin/dashboard/deleteservice"}}', // URL from data-request-url attribute
                        method: 'POST',
                        data: withCsrf({
                            serviceId: $('#serviceId').val()
                        }),
                        success: function(response) {
                            // Handle success response
                            Swal.fire({
                                    title: "Success!",
                                    text: "Service deleted successfully!",
                                    icon: "success",
                                    dangerMode: false
                                });

                                setTimeout(
                                    ReloadPage
                                    , 1500);
                        },
                        error: function(xhr, status, error) {
                            // Handle error response
                            console.error('Error deleting service:', error);
                            Swal.fire({
                                title: "Error!",
                                text: error,
                                icon: "error",
                                dangerMode: true
                            });
                        }
                    });
                }
        });
    });

    $('.edit-rate').on('click', function() {
        var rateId = $(this).data('id');

        $.ajax({
            url: '{{withBasePath "/admin/dashboard/getprintandsubrate"}}',
            method: 'POST',
            dataType: 'json',
            data: withCsrf({ rateId: rateId }),
            success: function(response) {
                const rate = response.rate;

                $('#rateId').val(rate.rateId);
                $('#rateMarket').val(rate.market);
                $('#rateType').val(rate.type);
                $('#rateDescription').val(rate.rateDescription);
                $('#printDayPattern').val(rate.printDayPattern);
                $('#printTerm').val(rate.printTerm);
                $('#printTermUnit').val(rate.printTermUnit);
                $('#eDayPattern').val(rate.eDayPattern);
                $('#eTerm').val(rate.term);
                $('#eTermUnit').val(rate.termUnit);
                $('#rateCurrency').val(rate.currency);
                $('#rateAmount').val(rate.rate);
                $('#sortOrder').val(rate.sortOrder);
                $('#rateActive').prop('checked', Boolean(rate.active));
            },
            error: function(err) {
                console.error(err);
                Swal.fire({
                    title: "Error!",
                    text: err.responseJSON?.message || 'Unable to load the rate.',
                    icon: "error",
                    dangerMode: true
                });
            }
        });
    });

    $('#editRateForm').submit(function(event) {
        event.preventDefault();

        $.ajax({
            url: $(this).data('request-url'),
            method: 'POST',
            data: withCsrf({
                rateId: $('#rateId').val(),
                rateMarket: $('#rateMarket').val(),
                rateType: $('#rateType').val(),
                rateDescription: $('#rateDescription').val(),
                printDayPattern: $('#printDayPattern').val(),
                printTerm: $('#printTerm').val(),
                printTermUnit: $('#printTermUnit').val(),
                eDayPattern: $('#eDayPattern').val(),
                eTerm: $('#eTerm').val(),
                eTermUnit: $('#eTermUnit').val(),
                rateCurrency: $('#rateCurrency').val(),
                rateAmount: $('#rateAmount').val(),
                sortOrder: $('#sortOrder').val(),
                rateActive: $('#rateActive').is(':checked')
            }),
            success: function(response) {
                if (response.success) {
                    Swal.fire({
                        title: "Success!",
                        text: "Rate updated successfully!",
                        icon: "success",
                        dangerMode: false
                    });

                    setTimeout(ReloadPage, 1500);
                } else {
                    Swal.fire({
                        title: "Error!",
                        text: "Something went wrong. Please try again later!",
                        icon: "warning",
                        dangerMode: true
                    });
                }
            },
            error: function(xhr, status, error) {
                console.error('Error updating rate:', error);
                Swal.fire({
                    title: "Error!",
                    text: xhr.responseJSON?.message || error,
                    icon: "error",
                    dangerMode: true
                });
            }
        });
    });

    $('#deleteRateBtn').click(function() {
        Swal.fire({
            title: "Are you sure?",
            text: "You won't be able to revert this!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, delete it!"
        }).then(function(result) {
            if (result.isConfirmed) {
                $.ajax({
                    url: '{{withBasePath "/admin/dashboard/deleteprintandsubrate"}}',
                    method: 'POST',
                    data: withCsrf({
                        rateId: $('#rateId').val()
                    }),
                    success: function(response) {
                        Swal.fire({
                            title: "Deleted!",
                            text: "The rate has been deleted.",
                            icon: "success"
                        });

                        setTimeout(ReloadPage, 1500);
                    },
                    error: function(xhr, status, error) {
                        console.error('Error deleting rate:', error);
                        Swal.fire({
                            title: "Error!",
                            text: xhr.responseJSON?.message || error,
                            icon: "error",
                            dangerMode: true
                        });
                    }
                });
            }
        });
    });
    
    // Listen for click event on category button
    document.addEventListener("DOMContentLoaded", function() {
        const createNewCategoryBtn = document.getElementById('createNewCategoryBtn');
        const editCategoryModal = document.getElementById('editCategoryModal');
        const editCategoryModalTitle = document.getElementById('editCategoryModalLabel');
        const editCategoryForm = document.getElementById('editCategoryForm');
        const categoryNameInput = document.getElementById('categoryName');
        const categoryDescInput = document.getElementById('categoryDesc');
        const categoryActiveCheckbox = document.getElementById('categoryActive');
        const deleteCategoryBtn = document.getElementById('deleteCategoryBtn');
        const updateCategoryBtn = document.getElementById('updateCategoryBtn');

        createNewCategoryBtn.addEventListener('click', function() {
            // Set modal title
            editCategoryModalTitle.textContent = 'Create New Category';

            // Set form action URL
            editCategoryForm.setAttribute('data-request-url', '{{withBasePath "/admin/dashboard/createcategory"}}');

            // Set button labels
            deleteCategoryBtn.style.display = 'none'; // Hide delete button
            updateCategoryBtn.textContent = 'Create'; // Change update button label

            // Reset form fields
            categoryNameInput.value = '';
            categoryDescInput.value = '';
            categoryActiveCheckbox.checked = false;
        });
        // Reset modal content when it is closed
        editCategoryModal.addEventListener('hidden.bs.modal', function() {
            // Reset modal title
            editCategoryModalTitle.textContent = 'Edit Category';

            // Reset form action URL
            editCategoryForm.setAttribute('data-request-url', '{{withBasePath "/admin/dashboard/updatecategory"}}');

            // Reset button labels
            deleteCategoryBtn.style.display = 'block'; // Show delete button
            updateCategoryBtn.textContent = 'Update'; // Reset update button label
        });
    
        const createNewServiceBtn = document.getElementById('createNewServiceBtn');
        const editServiceModal = document.getElementById('editServiceModal');
        const editServiceModalTitle = document.getElementById('editServiceModalLabel');
        const editServiceForm = document.getElementById('editServiceForm');
        const serviceIdInput = document.getElementById('serviceId');
        const serviceCategoryInput = document.getElementById('serviceCategory');
        const serviceNameInput = document.getElementById('serviceName');
        const serviceDescInput = document.getElementById('serviceDesc');
        const serviceCurrencyInput = document.getElementById('serviceCurrency');
        const servicePriceInput = document.getElementById('servicePrice');
        const serviceEpaperDaysInput = document.getElementById('serviceEpaperDays');
        const serviceUseSubscriptionRatesInput = document.getElementById('serviceUseSubscriptionRates');
        const subscriptionRateTypeInput = document.getElementById('subscriptionRateType');
        const serviceActiveCheckbox = document.getElementById('serviceActive');
        const deleteServiceBtn = document.getElementById('deleteServiceBtn');
        const updateServiceBtn = document.getElementById('updateServiceBtn');
        const createNewRateBtn = document.getElementById('createNewRateBtn');
        const editRateModal = document.getElementById('editRateModal');
        const editRateModalTitle = document.getElementById('editRateModalLabel');
        const editRateForm = document.getElementById('editRateForm');
        const deleteRateBtn = document.getElementById('deleteRateBtn');
        const updateRateBtn = document.getElementById('updateRateBtn');

        function syncServiceRateMode() {
            const useSubscriptionRates = serviceUseSubscriptionRatesInput.checked;

            serviceCurrencyInput.required = !useSubscriptionRates;
            servicePriceInput.required = !useSubscriptionRates;
            serviceCurrencyInput.disabled = useSubscriptionRates;
            servicePriceInput.disabled = useSubscriptionRates;
            subscriptionRateTypeInput.disabled = !useSubscriptionRates;
            subscriptionRateTypeInput.required = useSubscriptionRates;

            if (useSubscriptionRates) {
                serviceCurrencyInput.value = '';
                servicePriceInput.value = '';
            }
        }

        serviceUseSubscriptionRatesInput.addEventListener('change', syncServiceRateMode);

        createNewServiceBtn.addEventListener('click', function() {
            // Set modal title
            editServiceModalTitle.textContent = 'Create New Service';

            // Set form action URL
            editServiceForm.setAttribute('data-request-url', '{{withBasePath "/admin/dashboard/createservice"}}');

            // Set button labels
            deleteServiceBtn.style.display = 'none'; // Hide delete button
            updateServiceBtn.textContent = 'Create'; // Change update button label

            // Reset form fields
            serviceIdInput.value = ''; // Clear service ID
            serviceCategoryInput.value = ''; // Clear selected category
            serviceNameInput.value = '';
            serviceDescInput.value = '';
            serviceCurrencyInput.value = '';
            servicePriceInput.value = '';
            serviceEpaperDaysInput.value = '';
            serviceUseSubscriptionRatesInput.checked = false;
            subscriptionRateTypeInput.value = 'Epaper';
            serviceActiveCheckbox.checked = false;
            syncServiceRateMode();
        });

        // Reset modal content when it is closed
        editServiceModal.addEventListener('hidden.bs.modal', function() {
            // Reset modal title
            editServiceModalTitle.textContent = 'Edit Service';

            // Reset form action URL
            editServiceForm.setAttribute('data-request-url', '{{withBasePath "/admin/dashboard/updateservice"}}');

            // Reset button labels
            deleteServiceBtn.style.display = 'block'; // Show delete button
            updateServiceBtn.textContent = 'Update'; // Reset update button label
            syncServiceRateMode();
        });

        createNewRateBtn.addEventListener('click', function() {
            editRateModalTitle.textContent = 'Create New Subscription Rate';
            editRateForm.setAttribute('data-request-url', '{{withBasePath "/admin/dashboard/createprintandsubrate"}}');
            deleteRateBtn.style.display = 'none';
            updateRateBtn.textContent = 'Create';
            editRateForm.reset();
            document.getElementById('rateId').value = '';
            document.getElementById('rateActive').checked = true;
        });

        editRateModal.addEventListener('hidden.bs.modal', function() {
            editRateModalTitle.textContent = 'Edit Subscription Rate';
            editRateForm.setAttribute('data-request-url', '{{withBasePath "/admin/dashboard/updateprintandsubrate"}}');
            deleteRateBtn.style.display = 'block';
            updateRateBtn.textContent = 'Update';
        });
    });

</script>
