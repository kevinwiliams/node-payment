<!-- Edit Modal -->
<div class="modal fade" id="editServiceModal" tabindex="-1" aria-labelledby="editServiceModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editServiceModalLabel">Edit Service</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editServiceForm" name="editServiceForm" role="form" method="POST" class="g-3 needs-validation" data-request-url="{{withBasePath '/admin/dashboard/updateservice'}}" enctype="multipart/form-data">
        <div class="modal-body">
          <input type="hidden" class="form-control" id="serviceId" name="serviceId">

          <div class="row g-3">
            <div class="col-md-6">
              <label for="serviceCategory" class="form-label">Category</label>
              <select class="form-select" id="serviceCategory" name="serviceCategory" required>
                  <option value="">Select a category</option>
                {{#each categories}}
                  <option value="{{dataValues.categoryId}}">{{dataValues.name}}</option>
                {{/each}}
              </select>
            </div>
            <div class="col-md-6">
              <label for="serviceName" class="form-label">Service</label>
              <input type="text" class="form-control" id="serviceName" name="serviceName" required>
            </div>
            <div class="col-12">
              <label for="serviceDesc" class="form-label">Description</label>
              <textarea class="form-control" id="serviceDesc" name="serviceDesc" rows="3"></textarea>
            </div>
            <div class="col-md-4">
              <label for="serviceCurrency" class="form-label">Currency</label>
              <select name="serviceCurrency" id="serviceCurrency" class="form-select">
                <option value="" selected="true">Select Currency</option>
                <option value="JMD">JMD</option>
                <option value="USD">USD</option>
              </select>
            </div>
            <div class="col-md-4">
              <label for="servicePrice" class="form-label">Price</label>
              <input type="text" class="form-control" id="servicePrice" name="servicePrice" placeholder="00.00">
            </div>
            <div class="col-md-4">
              <label for="serviceEpaperDays" class="form-label">EPAPER Days</label>
              <input type="number" class="form-control" id="serviceEpaperDays" name="serviceEpaperDays">
            </div>
            <div class="col-12">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="serviceUseSubscriptionRates" name="serviceUseSubscriptionRates">
                <label class="form-check-label" for="serviceUseSubscriptionRates">
                  Use `printandsubrates` from Adhoc DB
                </label>
              </div>
              <div class="form-text">
                When enabled, this service uses the Adhoc subscription rate table instead of the service's own price at checkout.
              </div>
            </div>
            <div class="col-md-4">
              <label for="subscriptionRateType" class="form-label">Subscription Rate Type</label>
              <select class="form-select" id="subscriptionRateType" name="subscriptionRateType">
                <option value="Epaper">Epaper</option>
                <option value="Print">Print</option>
              </select>
              <div class="form-text">
                Choose which `Type` rows this service should load from `printandsubrates`.
              </div>
            </div>
            <div class="col-md-8">
              <label for="serviceImage" class="form-label">Upload Image</label>
              <input type="file" class="form-control" id="serviceImage" name="serviceImage" accept="image/*">
            </div>
            <div class="col-md-4 d-flex align-items-end">
              <div class="form-check form-switch mb-2">
                <input class="form-check-input" type="checkbox" value="" id="serviceActive" name="serviceActive">
                <label class="form-check-label" for="serviceActive">
                  Active
                </label>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer admin-modal-footer">
          <button type="button" class="btn btn-outline-danger" id="deleteServiceBtn">Delete</button>
          <button type="submit" class="btn btn-primary-custom text-white" id="updateServiceBtn">Update</button>
        </div>
      </form>
    </div>
  </div>
</div>
